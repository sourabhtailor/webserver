pipeline {
     agent any
     stages {
         stage('show the code') {
           steps {
               sh 'ls -al'
               sh 'cat jenkins.bak'
     }
   }
         stage('building the code') {
           steps {
             input message: """
	    Deploy to Gov Prod?

            """,
            ok: 'deploy'

            sh '''

              ls -al
              cat sourabh.txt
              '''
     }
   }  
 }
}

pipeline {
     agent any
     stages {
         stage('show the code') {
           steps {
               sh 'ls -al'
               sh 'cat jenkins.bak'
     }
   }
         stage('building the code') {
           steps {
             script {

		def commit = sh(script: "git rev-parse HEAD", returnStdout: true).trim()
		def author = sh(script: "git lod -1 --pretty=format:'%an'", returnStdout: true).trim()
		def message = sh(script: "git log -1 --pretty=format:'%s'", returnStdout: true).trim()
        
	        input message: """
	
	Deploy to Gov Prod?
	
	commit: "$commit"
	author: "$author"
	message: "$message"
        """,
            ok: 'deploy'

            sh '''

              ls -al
              cat sourabh.txt
              '''
     }
   }  
 }
}
}
